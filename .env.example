APP_NAME="SaaS Subscriptions"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=saas_subscriptions
DB_PGSQL_DATABASE=saas_subscriptions
DB_USERNAME=app_user
DB_PASSWORD=app_secret
DB_MIGRATE_USERNAME=migrate_user
DB_MIGRATE_PASSWORD=migrate_secret

# Use redis in production — database sessions are not tenant-isolated at DB layer
SESSION_DRIVER=redis
# Use sync for local/demo — switch to redis/database in production with a queue worker
QUEUE_CONNECTION=sync
CACHE_STORE=database

# Required in production — use a strong random value (never commit real secrets)
CRON_SECRET=change-me-in-production

# Sanctum token lifetime in minutes (default 24 hours)
SANCTUM_EXPIRATION=1440

BCRYPT_ROUNDS=12

# Set APP_DEBUG=false and rotate all secrets before production deployment
